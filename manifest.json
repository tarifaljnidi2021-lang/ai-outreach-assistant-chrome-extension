{
  "manifest_version": 3,
  "name": "LinkedIn Lead Extractor",
  "version": "1.0",
  "description": "Extract LinkedIn search results and send to API",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}